---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { entryPath } from '../../utils/permalink';

export async function getStaticPaths() {
  // The exact set of canonical URLs that MUST be preserved from the old Jekyll site
  // (proven against the live `master` tree). If the generated paths ever drift from
  // this list, the build fails loudly instead of silently breaking SEO/inbound links.
  // Defined inside getStaticPaths because Astro extracts this function in isolation.
  const CANONICAL_PATHS = [
    '/blog/2013/07/10/frege-hello-java/',
    '/blog/2014/03/15/frege-record-accessors-and-mutators/',
    '/blog/2016/02/27/haskell-on-the-jvm-via-ghcjs-and-nashorn/',
    '/blog/2017/01/06/introducing-idris-on-the-jvm-and-an-idris-android-example/',
    '/blog/2017/01/10/idris-jvm-guarding-against-java-null-using-maybe-type/',
    '/blog/2018/02/11/idris-jvm-automated-ffi-with-null-safety/',
    '/blog/2020/12/30/idris-2-bootstrap-compiler-on-the-jvm-with-a-jvm-backend/',
    '/blog/2021/07/24/idris-2-initial-release-0-dot-2-1-for-the-jvm/',
    '/blog/2024/07/15/idris-jvm-0-7-0-release/',
  ];

  const posts = await getCollection('blog');

  const generated = posts.map((post) => ({
    path: entryPath(post),
    // params.slug receives the multi-segment path between /blog/ and the trailing slash.
    params: { slug: entryPath(post).replace(/^\/blog\//, '').replace(/\/$/, '') },
    props: { post },
  }));

  // --- Build-time permalink assertion ---
  const got = generated.map((g) => g.path).sort();
  const want = [...CANONICAL_PATHS].sort();
  const missing = want.filter((p) => !got.includes(p));
  const extra = got.filter((p) => !want.includes(p));
  if (missing.length || extra.length) {
    throw new Error(
      'Post permalink mismatch — old URLs would break.\n' +
        (missing.length ? `  Missing (expected, not generated): ${missing.join(', ')}\n` : '') +
        (extra.length ? `  Unexpected (generated, not in canonical list): ${extra.join(', ')}\n` : '') +
        'Fix the post front-matter date or update CANONICAL_PATHS if a new post was added.'
    );
  }

  return generated.map(({ params, props }) => ({ params, props }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<PostLayout post={post}>
  <Content />
</PostLayout>
