---
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostListItem from '../../components/PostListItem.astro';
import { getSortedPosts } from '../../utils/posts';

// Mirrors the old Jekyll `paginate: 10` / `paginate_path: "posts/:num"`.
export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getSortedPosts();
  return paginate(posts, { pageSize: 10 });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<CollectionEntry<'blog'>>;
}
const { page } = Astro.props;
---
<BaseLayout title={`Posts — page ${page.currentPage}`}>
  <h1>Posts</h1>
  <ul class="post-list">
    {page.data.map((post) => <PostListItem post={post} />)}
  </ul>
  <nav class="post-meta">
    {page.url.prev && <a href={page.url.prev}>&larr; Newer</a>}
    {page.url.prev && page.url.next && <span> &middot; </span>}
    {page.url.next && <a href={page.url.next}>Older &rarr;</a>}
  </nav>
</BaseLayout>
