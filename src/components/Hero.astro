---
import {getCollection} from 'astro:content';
import {SITE_TITLE, SITE_DESCRIPTION, SITE_AUTHOR, SITE_AVATAR, SITE_COVER, SOCIAL_LINKS} from '../consts';
import {getWordCount, getReadingTime} from '../utils/readingTime';

const allBlogPosts = await getCollection('blog');
const sorted = allBlogPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

let totalMinutes = 0;

const categorySet = new Set<string>();
const tagSet = new Set<string>();

for (const post of sorted) {
    totalMinutes += getReadingTime(post.body || '');
    if (post.data.category) {
        const rootCat = post.data.category.split('/')[0];
        categorySet.add(rootCat);
    }
    for (const tag of post.data.tags || []) {
        tagSet.add(tag);
    }
}
---

<section class="relative overflow-hidden rounded-2xl mb-10 bg-[#0a0a0a]">
    <div class="absolute inset-0">
        {SITE_COVER && (
            <img
                    src={SITE_COVER}
                    alt=""
                    class="w-full h-full object-cover"
                    aria-hidden="true"
            />
        )}
        {/* Blue-to-black gradient base; an extra dark overlay when a cover image is set */}
        <div class="absolute inset-0 bg-linear-to-br from-primary/30 via-[#0a0a0a] to-[#0a0a0a]"></div>
        {SITE_COVER && <div class="absolute inset-0 bg-black/50"></div>}
    </div>

    <div class="relative px-6 py-12 sm:px-10 sm:py-16 lg:py-20 text-center text-white">

        <p class="text-lg sm:text-xl text-white/80 font-light mb-6">
            Hi, I'm {SITE_AUTHOR}. This is my personal blog, where I write about
            programming - with particular focus on Idris, Java, JVM.
        </p>

        <div class="flex items-center justify-center gap-4 mb-8">
            {SOCIAL_LINKS.map((link) => (
                    <a
                            href={link.href}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 backdrop-blur-sm transition-all duration-300 hover:scale-110"
                            title={link.name}
                    >
                        {link.icon === 'github' && (
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                                </svg>
                        )}
                        {link.icon === 'linkedin' && (
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.238 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                                </svg>
                        )}
                        {link.icon === 'rss' && (
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
                                </svg>
                        )}
                    </a>
            ))}
        </div>


    </div>
</section>
