---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

function pageUrl(page: number): string {
  if (page === 1) return baseUrl;
  return `${baseUrl}${baseUrl.endsWith('/') ? '' : '/'}page/${page}`;
}
---

{
  totalPages > 1 && (
    <nav class="flex items-center justify-center gap-2 mt-10">
      {
        currentPage > 1 && (
          <a
            href={pageUrl(currentPage - 1)}
            class="px-4 py-2 rounded-lg bg-white dark:bg-[var(--color-card-dark)] shadow-sm text-sm hover:text-primary transition-colors"
          >
            Previous
          </a>
        )
      }
      {
        Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
          <a
            href={pageUrl(page)}
            class={`px-4 py-2 rounded-lg text-sm transition-colors ${
              page === currentPage
                ? 'bg-primary text-white'
                : 'bg-white dark:bg-[var(--color-card-dark)] shadow-sm hover:text-primary'
            }`}
          >
            {page}
          </a>
        ))
      }
      {
        currentPage < totalPages && (
          <a
            href={pageUrl(currentPage + 1)}
            class="px-4 py-2 rounded-lg bg-white dark:bg-[var(--color-card-dark)] shadow-sm text-sm hover:text-primary transition-colors"
          >
            Next
          </a>
        )
      }
    </nav>
  )
}
