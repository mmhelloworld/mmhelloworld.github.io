---
interface Props {
  url: string;
  title: string;
  description?: string;
  favicon?: string;
  site?: string;
}

const { url, title, description, favicon, site } = Astro.props;

const hostname = site || new URL(url).hostname;
const fallbackIcon = `https://www.google.com/s2/favicons?domain=${hostname}&sz=32`;
const iconSrc = favicon || fallbackIcon;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="card-hover my-4 flex items-start gap-4 bg-white dark:bg-[var(--color-card-dark)] rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-4 no-underline group"
>
  <img
    src={iconSrc}
    alt={hostname}
    class="w-10 h-10 rounded-lg object-cover shrink-0 mt-0.5"
    loading="lazy"
    width="40"
    height="40"
    onerror="this.style.display='none'"
  />
  <div class="flex-1 min-w-0">
    <span class="block text-sm font-medium text-gray-900 dark:text-gray-100 group-hover:text-primary transition-colors">
      {title}
    </span>
    {description && (
      <span class="block text-xs text-gray-400 dark:text-gray-500 mt-1 line-clamp-2">
        {description}
      </span>
    )}
    <span class="inline-flex items-center gap-1 mt-1.5 text-xs text-gray-400 dark:text-gray-500">
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
      </svg>
      {hostname}
    </span>
  </div>
  <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 shrink-0 mt-2 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
  </svg>
</a>
